  "id": null,
  "links": [
    {
      "title": "Fookie Services",
      "type": "link",
      "url": "/d/fookie-services/fookie-services"
    },
    {
      "title": "Fookie Logs",
      "type": "link",
      "url": "/d/fookie-logs/fookie-logs"
    }
  ],
  "liveNow": true,
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=~\"$service\"} |= \"http_access\" [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Total requests",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "avg(avg_over_time({service=~\"$service\"} |= \"http_access\" | json | unwrap duration_ms [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Avg latency",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(15, sum by (route, method) (rate(http_requests_total{service=~\"$service\"}[1m])))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Requests" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "Avg ms" },
            "properties": [{ "id": "unit", "value": "ms" }, { "id": "custom.width", "value": 90 }]
          },
          {
            "matcher": { "id": "byName", "options": "P95 ms" },
            "properties": [{ "id": "unit", "value": "ms" }, { "id": "custom.width", "value": 90 }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Requests" }]
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(25, sum by (method, route) (count_over_time({service=~\"$service\"} |= \"http_access\" | json | route != \"\" [$__range])))",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(25, avg by (method, route) (avg_over_time({service=~\"$service\"} |= \"http_access\" | json | unwrap duration_ms | route != \"\" [$__range])))",
          "queryType": "instant",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(25, quantile_over_time(0.95, {service=~\"$service\"} |= \"http_access\" | json | unwrap duration_ms | route != \"\" [$__range]) by (method, route))",
          "queryType": "instant",
          "refId": "C"
        }
      ],
      "title": "Top routes (count / avg / p95 ms)",
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "route" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "Value #A": "Requests",
              "Value #B": "Avg ms",
              "Value #C": "P95 ms",
              "method": "Method",
              "route": "Route"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, route, method) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "p95 {{method}} {{route}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_request_duration_seconds_sum{service=~\"$service\"}[5m]) / clamp_min(rate(http_request_duration_seconds_count{service=~\"$service\"}[5m]), 1e-9)",
          "legendFormat": "avg {{method}} {{route}}",
          "refId": "B"
        }
      ],
      "title": "Latency by route (Prometheus)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [{ "id": "unit", "value": "ms" }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 14 },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Requests" }]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(30, sum by (method, route, query) (count_over_time({service=~\"$service\"} |= \"http_access\" | json | query != \"\" [$__range])))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top query params by route",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "Value": "Requests",
              "method": "Method",
              "query": "Query",
              "route": "Route"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 18 },
      "id": 7,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{service=~\"$service\", route=~\"$route\"} |= \"http_access\" | json | line_format \"{{.method}} {{.route}} status={{.status}} {{.duration_ms}}ms query={{.query}}\"",
          "queryType": "range",
          "refId": "A",
          "maxLines": 300
        }
      ],
      "title": "Access log stream",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["fookie", "http", "paths"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": ".+" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(service)",
        "includeAll": true,
        "allValue": ".+",
        "label": "Service",
        "name": "service",
        "query": "label_values(service)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": ".+" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({service=~\"$service\"}, route)",
        "includeAll": true,
        "allValue": ".+",
        "label": "Route",
        "name": "route",
        "query": "label_values({service=~\"$service\"}, route)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Fookie HTTP Paths",
  "uid": "fookie-http-paths",
  "version": 1
}
