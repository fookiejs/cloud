{
  "name": "@fookie/cloud-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @fookie/cloud-web && npm run build:modules && tsc -p packages/server/tsconfig.json",
    "build:modules": "npm --prefix ../task-bridge/apps/backend run build && npm --prefix ../script-manager/packages/gateway run build",
    "build:web": "npm run build --workspace @fookie/cloud-web",
    "build:server": "npm run build:modules && tsc -p packages/server/tsconfig.json",
    "dev": "npm run build:modules && tsx packages/server/src/index.ts",
    "dev:web": "npm run dev --workspace @fookie/cloud-web",
    "start": "node packages/server/dist/index.js",
    "typecheck": "npm run typecheck --workspace @fookie/cloud-web && npm run build:modules && tsc -p packages/server/tsconfig.json --noEmit",
    "test": "tsx --test packages/server/src/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/http-proxy": "^11.6.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "fastify": "5.8.5",
    "jose": "^6.0.11",
    "nanoid": "^5.0.9",
    "prom-client": "^15.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
