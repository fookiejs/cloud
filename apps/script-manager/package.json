{
    "name":  "script-manager",
    "version":  "0.2.34",
    "private":  true,
    "type":  "module",
    "description":  "Script Manager — Fookie Cloud local task orchestration",
    "workspaces":  [
                       "packages/*"
                   ],
    "scripts":  {
                    "dev":  "npm-run-all --parallel dev:server dev:web",
                    "dev:server":  "npm --workspace @script/server run dev",
                    "dev:web":  "npm --workspace @script/web run dev",
                    "dev:landing":  "npm --workspace @script/landing run dev",
                    "build:landing":  "npm --workspace @script/landing run build",
                    "build":  "npm --workspace @script/web run build \u0026\u0026 npm --workspace @script/server run build \u0026\u0026 node scripts/cp-public.mjs \u0026\u0026 npm --workspace @umudik/script run build",
                    "build:publish":  "node scripts/build-publish.mjs",
                    "lint":  "eslint \"packages/*/src/**/*.{ts,tsx}\"",
                    "format":  "prettier --write .",
                    "format:check":  "prettier --check .",
                    "typecheck":  "npm --workspace @script/server run typecheck \u0026\u0026 npm --workspace @script/web run typecheck \u0026\u0026 npm --workspace @script/landing run typecheck \u0026\u0026 npm --workspace @script/gateway run typecheck",
                    "dev:gateway":  "npm --workspace @script/gateway run dev",
                    "build:gateway":  "npm --workspace @script/landing run build \u0026\u0026 npm --workspace @script/gateway run build",
                    "test":  "npm --workspace @script/server run test"
                },
    "devDependencies":  {
                            "@typescript-eslint/eslint-plugin":  "^8.15.0",
                            "@typescript-eslint/parser":  "^8.15.0",
                            "eslint":  "^9.15.0",
                            "eslint-config-prettier":  "^10.1.5",
                            "prettier":  "^3.5.3",
                            "npm-run-all":  "^4.1.5",
                            "typescript":  "^5.6.3",
                            "typescript-eslint":  "^8.15.0"
                        },
    "engines":  {
                    "node":  "\u003e=26"
                }
}
